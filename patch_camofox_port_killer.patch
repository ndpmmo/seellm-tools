diff --git a/lib/port-killer.js b/lib/port-killer.js
new file mode 100644
index 0000000..296b03a
--- /dev/null
+++ b/lib/port-killer.js
@@ -0,0 +1,62 @@
+import { execSync } from 'child_process';
+
+/**
+ * Kill process occupying a specific port.
+ * @param {number} port 
+ * @param {object} [logger] - Optional logger object
+ */
+export function killProcessOnPort(port, logger) {
+  const logInfo = (msg) => {
+    if (logger && typeof logger.info === 'function') {
+      logger.info(msg);
+    } else {
+      console.log(`[PortKiller] ${msg}`);
+    }
+  };
+
+  try {
+    if (process.platform === 'win32') {
+      const stdout = execSync(`netstat -ano | findstr :${port}`, { stdio: ['ignore', 'pipe', 'ignore'] }).toString().trim();
+      if (stdout) {
+        const lines = stdout.split('\n');
+        for (const line of lines) {
+          const parts = line.trim().split(/\s+/);
+          const pid = parts[parts.length - 1];
+          if (pid && !isNaN(pid) && parseInt(pid, 10) !== process.pid) {
+            logInfo(`Killing process ${pid} occupying port ${port}`);
+            try {
+              execSync(`taskkill /F /PID ${pid}`, { stdio: 'ignore' });
+            } catch (_) {}
+          }
+        }
+      }
+    } else {
+      // macOS / Linux
+      const cmd = `lsof -t -i :${port}`;
+      const stdout = execSync(cmd, { stdio: ['ignore', 'pipe', 'ignore'] }).toString().trim();
+      if (stdout) {
+        const pids = stdout.split('\n').map(p => p.trim()).filter(Boolean);
+        for (const pid of pids) {
+          const pidNum = parseInt(pid, 10);
+          if (pidNum && pidNum !== process.pid) {
+            logInfo(`Killing process ${pidNum} occupying port ${port}`);
+            try {
+              process.kill(pidNum, 'SIGKILL');
+            } catch (killErr) {
+              try {
+                execSync(`kill -9 ${pidNum}`, { stdio: 'ignore' });
+              } catch (_) {}
+            }
+          }
+        }
+        // Give it a brief delay to release the socket
+        try {
+          execSync('sleep 0.5', { stdio: 'ignore' });
+        } catch (_) {}
+      }
+    }
+  } catch (err) {
+    // If lsof / netstat exits with non-zero code because port is not in use, it will throw.
+    // We swallow the error as it means no process is occupying the port.
+  }
+}
